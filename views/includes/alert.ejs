<% if(success && success.length) { %>
  <div class="alert alert-success" role="alert" class="col-6 offset-3">
    <%= success %>
    <button
    type="button"
    class="btn-close"
    data-bs-dismiss="alert"
    aria-label="close"
    ></button>
  </div>
<% } %>

<% if(error && error.length) { %>
<div class="alert alert-danger">
    <%= error %>
</div>
<% } %>